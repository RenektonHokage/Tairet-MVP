# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE=your-service-role-key
CLUB_VALID_WINDOW_CUTOFF_ISO=

# Email (Resend)
RESEND_API_KEY=re_xxxxxxxx
EMAIL_FROM_ADDRESS=reservas@tudominio.com
EMAIL_ENABLED=false
B2C_BASE_URL=https://tairet.com.py

# Recoverable access fulfillment (configuration is validated only when loaded)
# Explicit booleans accept only "true" or "false". Defaults shown below.
# Batch size: 1-100; poll interval: 1000-60000 ms; lease: 30-900 s;
# concurrency: 1-16.
# Legacy direct email cannot be combined with either the worker or durable email.
# Durable email additionally requires EMAIL_ENABLED=true and non-empty Resend/from values.
# Reconcile-only mode is worker=true + durable=false + legacy=false (dry-run may be either value).
# All three mode flags false pauses both legacy and durable delivery. Worker=false does not disable HTTP.
# Production and Railway values remain deliberately unverified/unconfigured in this slice.
ACCESS_FULFILLMENT_WORKER_ENABLED=false
ACCESS_DURABLE_EMAIL_DELIVERY_ENABLED=false
ACCESS_LEGACY_DIRECT_EMAIL_ENABLED=true
ACCESS_FULFILLMENT_WORKER_DRY_RUN=true
ACCESS_FULFILLMENT_BATCH_SIZE=5
ACCESS_FULFILLMENT_POLL_INTERVAL_MS=5000
ACCESS_FULFILLMENT_LEASE_SECONDS=300
ACCESS_FULFILLMENT_CONCURRENCY=2

# Bancard
BANCARD_PUBLIC_KEY=your-bancard-public-key
BANCARD_PRIVATE_KEY=your-bancard-private-key
BANCARD_BASE_URL=https://vpos.infonet.com.py:8888
BANCARD_ENVIRONMENT=staging
BANCARD_HTTP_TIMEOUT_MS=15000

# Server
PORT=4000
